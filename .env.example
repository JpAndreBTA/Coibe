PORTAL_TRANSPARENCIA_API_KEY=
PORTAL_TRANSPARENCIA_EMAIL=
PORTAL_TRANSPARENCIA_BASE_URL=https://api.portaldatransparencia.gov.br/api-de-dados

# Ambiente publico/producao. Em producao, docs e CORS aberto ficam bloqueados.
COIBE_ENV=production

# URL publica do backend. Use no frontend antes do build.
# Exemplo: VITE_API_BASE_URL=https://api.seu-dominio.com
VITE_API_BASE_URL=

# Origem publica do frontend para CORS. Separe multiplas por virgula.
# Exemplo: COIBE_CORS_ORIGINS=https://coibe.com.br,https://www.coibe.com.br
COIBE_CORS_ORIGINS=https://coibe.com.br,https://www.coibe.com.br

# Token para endpoints administrativos/pesados. Gere uma senha longa e nao publique.
# Use no header HTTP: X-Coibe-Admin-Token: valor-do-token
COIBE_ADMIN_TOKEN=
COIBE_REQUIRE_ADMIN_TOKEN=true
COIBE_ENABLE_STORAGE_STATUS=false
COIBE_ENABLE_DOCS=false

# Limites simples por IP/caminho para reduzir abuso via internet publica.
COIBE_RATE_LIMIT_ENABLED=true
COIBE_RATE_LIMIT_WINDOW_SECONDS=60
COIBE_RATE_LIMIT_PUBLIC_REQUESTS=120
COIBE_RATE_LIMIT_HEAVY_REQUESTS=12
COIBE_SCRAPE_MAX_BYTES=1048576
COIBE_SCRAPE_MAX_REDIRECTS=3

# Em deploy leve, deixe o monitor desligado e use dados/cache externos quando necessario.
COIBE_AUTO_MONITOR=false
COIBE_AUTO_MONITOR_INTERVAL_MINUTES=10
COIBE_AUTO_MONITOR_PAGES=3
COIBE_AUTO_MONITOR_PAGE_SIZE=30
COIBE_AUTO_MONITOR_API_BASE=http://127.0.0.1:8000

# Fontes publicas usadas pelo feed/monitor. Separe por virgula.
# compras = Compras.gov.br Dados Abertos; pncp = API Consulta PNCP.
COIBE_PUBLIC_CONTRACT_SOURCES=compras,pncp

# Enriquecimento por fornecedor: BrasilAPI sempre que aplicavel e Portal da
# Transparencia quando PORTAL_TRANSPARENCIA_API_KEY estiver configurada.
COIBE_PORTAL_TRANSPARENCIA_ENRICHMENT=true
COIBE_PUBLIC_DATA_ENRICHMENT_LIMIT=25

COIBE_MONITOR_LATEST_PATH=data/processed/latest_analysis.json
COIBE_MONITOR_DB_PATH=data/processed/monitoring_items.json
COIBE_PUBLIC_RECORDS_PATH=data/processed/public_api_records.json
COIBE_LIBRARY_PATH=data/library/library_records.jsonl
COIBE_LIBRARY_INDEX_PATH=data/library/library_index.json
COIBE_PUBLIC_CODES_PATH=data/library/public_codes.json
COIBE_SEARCH_CACHE_DIR=data/cache/search
COIBE_SEARCH_CACHE_TTL_HOURS=24

# Modelo adaptativo do monitor. O estado e historico ficam em Models/.
COIBE_MODELS_DIR=Models
COIBE_MODEL_LEARNED_TERMS_PER_CYCLE=12
COIBE_POLITICAL_PARTY_SCAN_LIMIT=12
COIBE_POLITICAL_PEOPLE_SCAN_LIMIT=24

# GPU opcional para ML. Requer bibliotecas compativeis, como cudf/cuml.
COIBE_ML_USE_GPU=false
COIBE_GPU_MEMORY_LIMIT_MB=2048

# Bucket S3 ou S3 compativel para hospedar os dados pesados da pasta data/.
# O backend baixa estes arquivos no startup:
# data/processed/latest_analysis.json
# data/processed/monitoring_items.json
# data/processed/public_api_records.json
# data/library/library_records.jsonl
# data/library/library_index.json
# data/library/public_codes.json
COIBE_DATA_S3_SYNC=false
COIBE_DATA_S3_WRITE_THROUGH=false
COIBE_DATA_LOCAL_CACHE=false
COIBE_DATA_S3_BUCKET=
COIBE_DATA_S3_PREFIX=data
COIBE_DATA_S3_ENDPOINT_URL=
COIBE_DATA_S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
